{
  "name": "pursue-pro",
  "displayName": "Pursue Post",
  "description": "A powerful REST API client for VS Code with collections, history, and a glossy UI",
  "version": "1.0.0",
  "publisher": "your-publisher-name",
  "repository": {
    "type": "git",
    "url": "https://example.com/your-repo.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onCommand:restClientPro.openClient",
    "onCommand:restClientPro.newRequest",
    "onCommand:restClientPro.clearHistory",
    "onCommand:restClientPro.openHistoryItem",
    "onCommand:restClientPro.openHistoryItemNewTab",
    "onCommand:restClientPro.saveHistoryItemToCollection",
    "onCommand:restClientPro.duplicateHistoryItem",
    "onCommand:restClientPro.deleteHistoryItem",
    "onCommand:restClientPro.renameHistoryItem",
    "onCommand:restClientPro.openCollection",
    "onCommand:restClientPro.deleteCollection",
    "onCommand:restClientPro.deleteCollectionItem",
    "onCommand:restClientPro.newCollection"
  ],
  "main": "./out/extension.js",
  "icon": "media/icon.png",
  "contributes": {
    "commands": [
      {
        "command": "restClientPro.openClient",
        "title": "Pursue Post: Open",
        "icon": "$(globe)"
      },
      {
        "command": "restClientPro.newRequest",
        "title": "Pursue Post: New Request",
        "icon": "$(add)"
      },
      {
        "command": "restClientPro.clearHistory",
        "title": "Pursue Post: Clear History"
      },
      {
        "command": "restClientPro.openHistoryItem",
        "title": "Open Request",
        "icon": "$(arrow-right)"
      },
      {
        "command": "restClientPro.openHistoryItemNewTab",
        "title": "Open in New Tab",
        "icon": "$(new-tab)"
      },
      {
        "command": "restClientPro.saveHistoryItemToCollection",
        "title": "Save to Collection",
        "icon": "$(save)"
      },
      {
        "command": "restClientPro.duplicateHistoryItem",
        "title": "Duplicate",
        "icon": "$(copy)"
      },
      {
        "command": "restClientPro.deleteHistoryItem",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "restClientPro.renameHistoryItem",
        "title": "Rename History Item"
      },
      {
        "command": "restClientPro.openCollection",
        "title": "Open Request",
        "icon": "$(arrow-right)"
      },
      {
        "command": "restClientPro.deleteCollection",
        "title": "Delete Collection",
        "icon": "$(trash)"
      },
      {
        "command": "restClientPro.deleteCollectionItem",
        "title": "Delete Request",
        "icon": "$(trash)"
      },
      {
        "command": "restClientPro.newCollection",
        "title": "New Collection",
        "icon": "$(add)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "restClientPro",
          "title": "Pursue Post",
          "icon": "$(globe)"
        }
      ]
    },
    "views": {
      "restClientPro": [
        {
          "id": "restClientPro.history",
          "name": "History"
        },
        {
          "id": "restClientPro.collections",
          "name": "Collections"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "restClientPro.newRequest",
          "when": "view == restClientPro.history",
          "group": "navigation"
        },
        {
          "command": "restClientPro.clearHistory",
          "when": "view == restClientPro.history"
        },
        {
          "command": "restClientPro.newCollection",
          "when": "view == restClientPro.collections",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "restClientPro.openHistoryItem",
          "when": "view == restClientPro.history && viewItem == historyItem",
          "group": "inline"
        },
        {
          "command": "restClientPro.openHistoryItemNewTab",
          "when": "view == restClientPro.history && viewItem == historyItem",
          "group": "inline"
        },
        {
          "command": "restClientPro.saveHistoryItemToCollection",
          "when": "view == restClientPro.history && viewItem == historyItem",
          "group": "inline"
        },
        {
          "command": "restClientPro.renameHistoryItem",
          "when": "view == restClientPro.history && viewItem == historyItem",
          "group": "inline"
        },
        {
          "command": "restClientPro.duplicateHistoryItem",
          "when": "view == restClientPro.history && viewItem == historyItem",
          "group": "inline"
        },
        {
          "command": "restClientPro.deleteHistoryItem",
          "when": "view == restClientPro.history && viewItem == historyItem",
          "group": "inline"
        },
        {
          "command": "restClientPro.openCollection",
          "when": "view == restClientPro.collections && viewItem == collectionItem",
          "group": "inline"
        },
        {
          "command": "restClientPro.deleteCollectionItem",
          "when": "view == restClientPro.collections && viewItem == collectionItem",
          "group": "inline"
        },
        {
          "command": "restClientPro.deleteCollection",
          "when": "view == restClientPro.collections && viewItem == collection",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build": "npm run compile && npm run build:webview",
    "build:webview": "cd webview && npm install && npm run build",
    "package": "npm run build && npx @vscode/vsce package --no-dependencies --allow-missing-repository --skip-license",
    "install-extension": "npm run package && code --install-extension pursue-pro-1.0.0.vsix",
    "install-only": "code --install-extension pursue-pro-1.0.0.vsix",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "overrides": {
    "cheerio": "1.0.0-rc.9"
  }
}